# Copie este arquivo para ".env" para rodar a API localmente (fora do Docker),
# apontando para os servicos do MongoDB/RabbitMQ/Kafka expostos pelo
# docker-compose (docker-compose up) ou rodando localmente nessas portas.

MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=orders_db
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
